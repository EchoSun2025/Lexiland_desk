# 环境变量配置

# OpenAI API
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Text AI provider for word/phrase annotation and card note replies.
# Use "openai" for the current cloud flow, or "local" for a local OpenAI-compatible server.
AI_TEXT_PROVIDER=openai

# Local model settings (used when AI_TEXT_PROVIDER=local)
# Ollama example:
#   LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
#   LOCAL_LLM_MODEL=qwen2.5:7b
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_LLM_MODEL=qwen2.5:7b
LOCAL_LLM_API_KEY=ollama

# 后端配置
PORT=3000
API_SECRET=your-secret-key-here
LEARNING_DATA_DIR=D:\0_EnglishLearning

# 前端 API 地址
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
VITE_API_URL=http://localhost:3000

# 开发模式
NODE_ENV=development
